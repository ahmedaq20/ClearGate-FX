meta {
  name: Queue Profit Summary PDF Export
  type: http
  seq: 14
}

post {
  url: {{baseUrlApi}}/reports/export
  body: json
  auth: bearer
}

headers {
  Accept: application/json
  Content-Type: application/json
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "type": "profit-summary",
    "format": "pdf",
    "params": {
      "date_from": "2026-06-01",
      "date_to": "2026-06-30"
    }
  }
}
