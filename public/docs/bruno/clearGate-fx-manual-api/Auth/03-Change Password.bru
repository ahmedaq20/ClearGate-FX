meta {
  name: Change Password
  type: http
  seq: 3
}

put {
  url: {{baseUrlApi}}/auth/change-password
  body: json
  auth: bearer
}

headers {
  Accept: application/json
  Content-Type: application/json
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "current_password": "password",
    "password": "new-password-123",
    "password_confirmation": "new-password-123"
  }
}
