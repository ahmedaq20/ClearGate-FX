meta {
  name: Transfer Capital To Box
  type: http
  seq: 4
}

post {
  url: {{baseUrlApi}}/capital/transfer-to-box
  body: json
  auth: bearer
}

headers {
  Accept: application/json
  Content-Type: application/json
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "box_id": 1,
    "amount": 500,
    "transaction_date": "2026-06-18",
    "notes": "Fund Turkish main box from owner capital"
  }
  
}
