meta {
  name: Update Settings
  type: http
  seq: 4
}

put {
  url: {{baseUrlApi}}/settings
  body: json
  auth: bearer
}

headers {
  Accept: application/json
  Content-Type: application/json
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "settings": {
      "shop_name": "ClearGate FX",
      "default_currency": "USD",
      "low_balance_alert_usd": 100
    }
  }
}
