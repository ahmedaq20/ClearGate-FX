}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "name": "Turkish Main Box Updated",
    "currency": "USD",
    "assigned_user_id": 2,
    "status": "active",
    "notes": "Updated Turkish box notes"
  }
}
