meta {
  name: Create User
  type: http
  seq: 2
}

post {
  url: {{baseUrlApi}}/users
  body: json
  auth: bearer
}

headers {
  Accept: application/json
  Content-Type: application/json
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "name": "Nadia Manager",
