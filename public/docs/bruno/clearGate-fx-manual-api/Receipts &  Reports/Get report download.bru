meta {
  name: Get report download
  type: http
  seq: 1
}

get {
  url: {{baseUrlApi}}/reports/export/replace-with-job-id/download
  body: none
  auth: bearer
}

headers {
  Accept: application/json
}

auth:bearer {
  token: {{token}}
}

settings {
  encodeUrl: true
  timeout: 0
  followRedirects: true
  maxRedirects: 5
}
